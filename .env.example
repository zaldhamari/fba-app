# Copy this file to .env and fill in the values.
# EXPO_PUBLIC_* variables are safe for client bundles — never put secrets here.

# Backend API key — must match API_KEY on Railway service
EXPO_PUBLIC_API_KEY=

# Backend URL — swap to staging URL without touching code
# Default (if omitted): https://fba-backend-production-6c44.up.railway.app/api
EXPO_PUBLIC_API_URL=

# RevenueCat public SDK key (iOS)
# DEV/staging: use test_ key from RC dashboard
# Production: use live appl_ key before App Store submission
EXPO_PUBLIC_RC_KEY_IOS=

# RevenueCat public SDK key (Android) — leave blank for iOS-only
EXPO_PUBLIC_RC_KEY_ANDROID=

# Sentry DSN — sentry.io → Project → Settings → Client Keys (DSN)
# Crash reporting is disabled in dev (enabled: !__DEV__)
EXPO_PUBLIC_SENTRY_DSN=
