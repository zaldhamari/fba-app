# ─── Backend API key (must match API_KEY env var set on Railway) ───────────────
# Generate with: openssl rand -hex 32
EXPO_PUBLIC_API_KEY=REPLACE_WITH_YOUR_API_KEY

# ─── RevenueCat (public keys — safe to commit after you set them) ─────────────
# DEV/STAGING: test_xxx key is fine for TestFlight builds
# PRODUCTION: replace with live appl_xxx key before App Store submission
EXPO_PUBLIC_RC_KEY_IOS=test_FNnILrueCvDwwBDFLWnygvibDdw
EXPO_PUBLIC_RC_KEY_ANDROID=REPLACE_WITH_RC_ANDROID_KEY

# ─── Sentry crash reporting ────────────────────────────────────────────────────
# Get DSN from: sentry.io → Project → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=REPLACE_WITH_SENTRY_DSN
